{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "api-lite": {
      "entrypoint": "backend/index.py",
      "routePrefix": "/api",
      "framework": "fastapi",
      "memory": 2048,
      "maxDuration": 300,
      "includeFiles": [
        "backend/risk_labels.json",
        "backend/risk_model.tflite",
        "backend/risk_rules.yaml"
      ],
      "excludeFiles": [
        ".venv/**",
        "uploads/**",
        "**/__pycache__/**",
        "**/*.pyc",
        "*.log",
        "requirements-train.txt",
        "train_risk_model.py",
        "risk_model.keras",
        "backend/.venv/**",
        "backend/uploads/**",
        "backend/**/__pycache__/**",
        "backend/**/*.pyc",
        "backend/*.log",
        "backend/requirements-train.txt",
        "backend/train_risk_model.py",
        "backend/risk_model.keras"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/qa",
      "destination": "/index.html"
    },
    {
      "source": "/risks",
      "destination": "/index.html"
    }
  ]
}
